{
  "name": "@hypedexer/sdk",
  "version": "0.1.0-beta.1",
  "description": "TypeScript SDK for the Hypedexer Hyperliquid indexer API",
  "license": "MIT",
  "author": "hypedexer",
  "homepage": "https://github.com/Hypedexer/hypedexer-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hypedexer/hypedexer-sdk.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Hypedexer/hypedexer-sdk/issues"
  },
  "keywords": ["hyperliquid", "hypedexer", "indexer", "perp", "spot", "sdk", "typescript"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": {
    "node": ">=20.18.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ws": "^8.18.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/ws": "^8.5.13",
    "tsup": "8.3.5",
    "vitest": "2.1.8",
    "ws": "^8.18.0"
  }
}
